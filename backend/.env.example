# =============================================================================
# AI Customs Backend — Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust values for your environment:
#   cp .env.example .env
# All variables are optional; the defaults below match backend/config/.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment: development | production | test | high_accuracy
ENVIRONMENT=development

# Admin API key (leave blank if unused)
ADMIN_API_KEY=

# Server bind address / port
HOST=0.0.0.0
PORT=8000

# CORS / cookie settings
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
COOKIE_DOMAIN=localhost

# -----------------------------------------------------------------------------
# LLM inference server (OpenAI-compatible endpoint: TGI or vLLM)
# -----------------------------------------------------------------------------
# Primary endpoint. When the backend runs in Docker and the model is served on
# the host, use host.docker.internal. When both run on the same Docker network,
# use the model container name, e.g. http://tgi:80/v1/ or http://vllm:80/v1/.
LLM_BASE_URL=http://host.docker.internal:8080/v1/

# Fallback endpoint for Linux containers where host.docker.internal doesn't resolve
LLM_BASE_URL_FALLBACK=http://172.17.0.1:8080/v1/

# Model identifier as registered with the inference server
LLM_SERVICE_TYPE=gemma-3-27b-it

# Generation parameters
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=8000
LLM_TOP_P=1.0

# Request timing (seconds)
LLM_REQUEST_TIMEOUT=120
LLM_CONNECT_TIMEOUT=30
LLM_REQUEST_DELAY=0.1

# -----------------------------------------------------------------------------
# Pipeline & analysis
# -----------------------------------------------------------------------------
PIPELINE_MAX_CONCURRENT=2
PIPELINE_QUEUE_SIZE=10

LLM_CONFIDENCE_THRESHOLD=0.75
LLM_ANALYSIS_TIMEOUT=180
LLM_MAX_RETRIES=3
LLM_DEEP_ANALYSIS=true

HEALTH_CHECK_TIMEOUT=5
RETRY_EXPONENTIAL_BASE=2

# -----------------------------------------------------------------------------
# PDF parsing (Docling / OCR)
# -----------------------------------------------------------------------------
PDF_MAX_FILE_SIZE_MB=50
PDF_TIMEOUT_SECONDS=300
PDF_MIN_DOCUMENTS=2
PDF_MAX_DOCUMENTS=5
PDF_SUPPORTED_FORMATS=pdf,jpg,png

PDF_ENABLE_OCR=true
PDF_ENABLE_TABLES=true
PDF_OCR_LANGUAGES=en,es,fr
PDF_FORCE_FULL_PAGE_OCR=false

# -----------------------------------------------------------------------------
# Background task queue (Huey)
# -----------------------------------------------------------------------------
# Used only when ENVIRONMENT=production (SQLite-backed queue).
HUEY_DATABASE_PATH=/app/database/huey.db
