# TGI Configuration Template
# Copy this file to .env and customize for your deployment

# ==============================================================================
# MODEL CONFIGURATION
# ==============================================================================

# Path to your downloaded models on the host
MODEL_HOST_PATH=./models

# Hugging Face token for private models (optional)
# HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# ==============================================================================
# GPU CONFIGURATION
# ==============================================================================

# Number of GPU shards to use (auto, 1, 2, 4, etc.)
TGI_NUM_SHARD=auto

# Which GPUs to use (all, 0, 0,1, 0,1,2,3, etc.)
CUDA_VISIBLE_DEVICES=all

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================

# Maximum concurrent requests (adjust based on GPU memory)
# 24GB GPUs: 64, 48GB+ GPUs: 256
TGI_MAX_CONCURRENT_REQUESTS=128

# Input length limits
TGI_MAX_INPUT_LENGTH=4096
TGI_MAX_TOTAL_TOKENS=8192

# Batch processing limits
TGI_MAX_BATCH_PREFILL_TOKENS=4096
TGI_MAX_BATCH_TOTAL_TOKENS=8192

# Response parameters
TGI_MAX_BEST_OF=2
TGI_MAX_STOP_SEQUENCES=4
TGI_WAITING_SERVED_RATIO=1.2

# ==============================================================================
# SERVICE CONFIGURATION
# ==============================================================================

# Service host and port
TGI_HOST=0.0.0.0
TGI_PORT=8080

# Enable trust remote code for custom models
TGI_TRUST_REMOTE_CODE=true

# Log level (DEBUG, INFO, WARN, ERROR)
TGI_LOG_LEVEL=INFO
RUST_LOG=info

# ==============================================================================
# MEMORY OPTIMIZATION PRESETS
# ==============================================================================

# Uncomment one of these presets based on your GPU memory:

# For 24GB GPUs (RTX 4090, RTX 3090, etc.)
# TGI_MAX_CONCURRENT_REQUESTS=64
# TGI_MAX_TOTAL_TOKENS=4096
# TGI_MAX_BATCH_PREFILL_TOKENS=2048
# TGI_MAX_BATCH_TOTAL_TOKENS=4096

# For 48GB+ GPUs (A100, H100, etc.)
# TGI_MAX_CONCURRENT_REQUESTS=256
# TGI_MAX_TOTAL_TOKENS=8192
# TGI_MAX_BATCH_PREFILL_TOKENS=4096
# TGI_MAX_BATCH_TOTAL_TOKENS=8192

# For low memory situations
# TGI_MAX_CONCURRENT_REQUESTS=32
# TGI_MAX_TOTAL_TOKENS=2048
# TGI_MAX_BATCH_PREFILL_TOKENS=1024
# TGI_MAX_BATCH_TOTAL_TOKENS=2048

# ==============================================================================
# LATENCY OPTIMIZATION
# ==============================================================================

# For lower latency (use smaller values)
# TGI_WAITING_SERVED_RATIO=0.8
# TGI_MAX_BATCH_PREFILL_TOKENS=1024
# TGI_MAX_BATCH_TOTAL_TOKENS=2048

# For higher throughput (use larger values)
# TGI_WAITING_SERVED_RATIO=1.5
# TGI_MAX_BATCH_PREFILL_TOKENS=8192
# TGI_MAX_BATCH_TOTAL_TOKENS=16384

# ==============================================================================
# DEVELOPMENT & DEBUGGING
# ==============================================================================

# Enable debug logging
# TGI_LOG_LEVEL=DEBUG
# RUST_LOG=debug

# Enable metrics endpoint
# TGI_METRICS=true

# ==============================================================================
# DOCKER COMPOSE OVERRIDES
# ==============================================================================

# Uncomment to override Docker Compose settings
# COMPOSE_PROJECT_NAME=tgi-gemma3
# COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml 